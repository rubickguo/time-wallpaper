{
  "name": "time-wallpaper",
  "version": "0.1.3",
  "private": false,
  "description": "A privacy-first Windows memory wallpaper client.",
  "author": "Time Wallpaper Contributors",
  "main": "src/main/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "npm run build && electron-builder --win nsis zip",
    "release:github": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish-release.ps1"
  },
  "build": {
    "appId": "com.timewallpaper.app",
    "productName": "时间壁纸",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/main/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "exifr": "^7.1.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1"
  }
}
